# Canonical origin. Used for metadataBase, sitemap.xml, robots.txt and OG tags.
# Set this to your real domain before building for production.
NEXT_PUBLIC_SITE_URL=https://loxy.lol

# --- Contact form (optional) ----------------------------------------------
# This site builds to static files, so there's no server of ours to POST to.
# Point this at any form service that accepts a JSON POST and returns 2xx:
#
#   Formspree    https://formspree.io/f/YOUR_ID
#   Web3Forms    https://api.web3forms.com/submit   (send access_key in body)
#   Basin        https://usebasin.com/f/YOUR_ID
#
# Leave it unset and the form falls back to opening a pre-filled email in the
# visitor's mail client — still functional, just one extra click for them.
NEXT_PUBLIC_FORM_ENDPOINT=
